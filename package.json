{
  "name": "odlingsguiden-monorepo",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/web",
    "build": "npm run build -w packages/web",
    "prerender": "npm run prerender -w packages/web",
    "preview": "npm run preview -w packages/web",
    "version": "npm run build -w packages/web && npm run prerender -w packages/web && git add packages/web/dist/"
  }
}
